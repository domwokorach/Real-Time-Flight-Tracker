    "globals": "^16.2.0",
    "jsdom": "^29.0.1",
    "node-fetch": "^3.3.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^4.1.2"
